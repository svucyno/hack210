# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_SUPABASE_PROJECT_ID=your_project_id

# OpenWeather API (Get free key from https://openweathermap.org/api)
VITE_OPENWEATHER_API_KEY=your_openweather_api_key

# Gemini API Keys (Multiple for fallback)
# Get from https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY_1=your_gemini_api_key_1
VITE_GEMINI_API_KEY_2=your_gemini_api_key_2
VITE_GEMINI_API_KEY_3=your_gemini_api_key_3
VITE_GEMINI_API_KEY=your_gemini_api_key

# Google Cloud API Key (for Text-to-Speech)
VITE_GOOGLE_CLOUD_API_KEY=your_google_cloud_api_key

# Groq API Keys (Multiple for fallback) - REQUIRED FOR FARMER ASSISTANT
# Get from https://console.groq.com/keys
VITE_GROQ_API_KEY_1=your_groq_api_key_1
VITE_GROQ_API_KEY_2=your_groq_api_key_2
VITE_GROQ_API_KEY=your_groq_api_key

# n8n Crop Advisor Webhook URL
VITE_N8N_CROP_ADVISOR_URL=your_n8n_webhook_url
